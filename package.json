{
  "name": "@wgw/workspace",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "tools/with-root-env.sh run 'export WGW_PROXY_TARGET=http://127.0.0.1:9080 && php packages/api/artisan wgw:dev-install && turbo run typegen:watch dev --filter=@wgw/api dev:app dev:storybook --filter=@wgw/apps --concurrency=20'",
    "dev:bootstrap": "php packages/api/artisan wgw:dev-install && pnpm --filter @wgw/apps run build:dev",
    "dev:api": "tools/with-root-env.sh -- turbo run dev --filter=@wgw/api",
    "dev:ui": "pnpm run dev",
    "dev:storybook": "tools/with-root-env.sh -- turbo run dev:storybook --filter=@wgw/apps",
    "preview": "tools/with-root-env.sh run 'export WGW_PROXY_TARGET=http://127.0.0.1:9080 && pnpm run preview:bootstrap && turbo run preview --filter=@wgw/api --filter=@wgw/apps --concurrency=20'",
    "preview:bootstrap": "composer --working-dir packages/api install --no-interaction --prefer-dist && php packages/api/artisan wgw:dev-install && pnpm --filter @wgw/apps run build",
    "setup:storybook-live-api": "bash tools/setup-storybook-live-api.sh --set-password",
    "test:collab-api": "bash tools/test-collab-api.sh",
    "test:meet-api": "bash tools/test-meet-api.sh",
    "build": "tools/with-root-env.sh -- turbo run typegen build --filter=@wgw/api --filter=@wgw/apps",
    "ci:quality": "pnpm run ci:quality:api && pnpm run ci:quality:apps",
    "ci:quality:api": "tools/with-root-env.sh -- turbo run typegen typegen:check lint format:check typecheck test --filter=@wgw/api",
    "ci:quality:apps": "tools/with-root-env.sh -- turbo run typegen typegen:check lint format:check --filter=@wgw/apps && pnpm run check:agent-docs && pnpm run test:apps-done-gate",
    "check:api-types": "tools/with-root-env.sh -- turbo run typegen:check --filter=@wgw/api",
    "lint": "tools/with-root-env.sh -- turbo run lint --filter=@wgw/api --filter=@wgw/apps",
    "format:check": "tools/with-root-env.sh -- turbo run format:check --filter=@wgw/api --filter=@wgw/apps",
    "check:licenses": "node tools/check-licenses.mjs",
    "check:agent-docs": "node tools/check-agent-doc-links.mjs",
    "check:storybook-coverage": "pnpm --filter @wgw/apps run check:storybook-coverage",
    "typecheck": "tools/with-root-env.sh -- turbo run typegen typecheck --filter=@wgw/apps",
    "test": "tools/with-root-env.sh -- turbo run test --filter=@wgw/api",
    "test:api-done-gate": "pnpm test",
    "test:apps-done-gate": "pnpm --filter @wgw/apps run test:done-gate",
    "test:api-e2e": "tools/with-root-env.sh -- pnpm --filter @wgw/api test:e2e",
    "test:api-e2e:docker": "tools/with-root-env.sh -- bash tools/test-api-e2e-docker.sh",
    "test:apps-e2e": "tools/with-root-env.sh -- pnpm --filter @wgw/apps test:e2e",
    "docker:up": "docker compose -f compose.dev.yml up -d --build",
    "docker:down": "docker compose -f compose.dev.yml down",
    "docker:logs": "docker compose -f compose.dev.yml logs -f",
    "docker:up:https": "docker compose -f compose.dev.yml -f compose.local.yml up -d --build",
    "docker:down:https": "docker compose -f compose.dev.yml -f compose.local.yml down",
    "docker:logs:https": "docker compose -f compose.dev.yml -f compose.local.yml logs -f",
    "docker:ssl:setup": "bash tools/docker-ssl-setup.sh",
    "release": "tools/with-root-env.sh -- bash tools/release-wegotworkspace.sh package",
    "release:publish": "tools/with-root-env.sh -- bash tools/release-wegotworkspace.sh publish",
    "release:wegotworkspace": "pnpm release",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "turbo": "^2.4.4"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1"
    }
  }
}
