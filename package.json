{
  "name": "@wgw/workspace",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "tools/with-root-env.sh run 'pnpm run dev:bootstrap && turbo run typegen:watch dev --filter=@wgw/api watch dev --filter=@wgw/apps --concurrency=20'",
    "dev:bootstrap": "pnpm --filter @wgw/apps run build:dev",
    "dev:api": "tools/with-root-env.sh -- turbo run dev --filter=@wgw/api",
    "dev:ui": "tools/with-root-env.sh run 'pnpm run dev:bootstrap && turbo run watch dev --filter=@wgw/apps --concurrency=20'",
    "dev:preview": "tools/with-root-env.sh run 'composer --working-dir packages/api install --no-interaction --prefer-dist && pnpm --filter @wgw/apps run build:dev && pnpm --filter @wgw/apps run sync:runtime && pnpm --filter @wgw/api run sync:runtime && turbo run watch:runtime --filter=@wgw/api --filter=@wgw/apps --concurrency=20'",
    "dev:storybook": "tools/with-root-env.sh -- turbo run dev --filter=@wgw/apps",
    "dev:onlyoffice": "tools/with-root-env.sh -- turbo run dev --filter=@wgw/onlyoffice-web",
    "build": "tools/with-root-env.sh -- turbo run typegen build",
    "ci:quality": "tools/with-root-env.sh -- turbo run typegen typegen:check lint format:check typecheck test --filter=@wgw/api --filter=@wgw/apps",
    "check:api-types": "tools/with-root-env.sh -- turbo run typegen:check --filter=@wgw/api",
    "lint": "tools/with-root-env.sh -- turbo run lint --filter=@wgw/api --filter=@wgw/apps",
    "format:check": "tools/with-root-env.sh -- turbo run format:check --filter=@wgw/api --filter=@wgw/apps",
    "typecheck": "tools/with-root-env.sh -- turbo run typegen typecheck --filter=@wgw/apps",
    "test": "tools/with-root-env.sh -- turbo run test --filter=@wgw/api",
    "test:api-done-gate": "pnpm test",
    "test:api-e2e": "tools/with-root-env.sh -- pnpm --filter @wgw/api test:e2e",
    "test:api-e2e:docker": "tools/with-root-env.sh -- bash tools/test-api-e2e-docker.sh",
    "docker:up": "docker compose -f compose.dev.yml up -d --build",
    "docker:down": "docker compose -f compose.dev.yml down",
    "docker:logs": "docker compose -f compose.dev.yml logs -f",
    "docker:ssl:setup": "bash tools/docker-ssl-setup.sh",
    "update:onlyoffice-web": "bash tools/update-onlyoffice-web-subtree.sh",
    "release": "tools/with-root-env.sh -- bash tools/release-wegotworkspace.sh package",
    "release:publish": "tools/with-root-env.sh -- bash tools/release-wegotworkspace.sh publish",
    "release:wegotworkspace": "pnpm release",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "turbo": "^2.4.4"
  }
}
