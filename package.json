{
  "name": "@wgw/workspace",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "tools/with-root-env.sh run 'pnpm run dev:bootstrap && turbo run typegen:watch --filter=@wgw/api watch dev --filter=@wgw/apps --concurrency=20'",
    "dev:bootstrap": "pnpm --filter @wgw/apps run build:dev",
    "dev:api": "tools/with-root-env.sh -- turbo run dev:php --filter=@wgw/api",
    "dev:php": "pnpm run dev:api",
    "dev:preview": "tools/with-root-env.sh run 'composer --working-dir packages/api install --no-interaction --prefer-dist && pnpm --filter @wgw/apps run build:dev && pnpm --filter @wgw/apps run sync:runtime && pnpm --filter @wgw/api run sync:runtime && turbo run watch:runtime --filter=@wgw/api --filter=@wgw/apps --concurrency=20'",
    "dev:ui:watch": "pnpm run dev",
    "dev:storybook": "tools/with-root-env.sh -- turbo run dev --filter=@wgw/apps",
    "dev:onlyoffice": "tools/with-root-env.sh -- turbo run dev --filter=@wgw/onlyoffice-web",
    "build": "tools/with-root-env.sh -- turbo run typegen build",
    "check:api-types": "tools/with-root-env.sh -- turbo run typegen:check --filter=@wgw/api",
    "test": "tools/with-root-env.sh -- turbo run test --filter=@wgw/api",
    "test:api-e2e": "tools/with-root-env.sh -- pnpm --filter @wgw/api test:e2e",
    "setup:macos": "tools/with-root-env.sh -- pnpm --filter @wgw/api setup:macos",
    "preview:macos": "tools/with-root-env.sh -- pnpm --filter @wgw/api preview:macos",
    "update:onlyoffice-web": "bash tools/update-onlyoffice-web-subtree.sh",
    "release": "node tools/build-wegotworkspace-release.mjs",
    "release:wegotworkspace": "pnpm release"
  },
  "devDependencies": {
    "turbo": "^2.4.4"
  }
}
