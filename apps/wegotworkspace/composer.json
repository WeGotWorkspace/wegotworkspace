{
    "name": "wegotworkspace/wegotworkspace",
    "description": "Thin WeGotWorkspace deploy app (entrypoint, routing shell, runtime config)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "wgw/api": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/api",
            "options": {
                "symlink": true
            }
        }
    ],
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "vendor-dir": "vendor",
        "audit": {
            "block-insecure": false
        }
    },
    "scripts": {
        "test": "phpunit -c ../../packages/api/phpunit.xml"
    }
}
