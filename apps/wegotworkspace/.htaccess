Options -Indexes -MultiViews

# PWA ships index.html beside index.php for Workbox precache; always route "/" through Laravel
# so unconfigured installs redirect to /install/ (see UiStaticFront).
<IfModule mod_dir.c>
    DirectoryIndex index.php
</IfModule>

# WebAssembly assets: ensure correct Content-Type when host mime.types omits .wasm.
<IfModule mod_mime.c>
    AddType application/wasm .wasm
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Never expose runtime internals, config, or source trees directly.
    RewriteRule ^(?:wgw-modules|wgw-private|wgw-content)(?:/|$) - [F,L,NC]
    RewriteRule ^(?:wgw-src|src|resources|vendor|scripts|patches|config|public|packages)(?:/|$) - [F,L,NC]
    RewriteRule ^(?:composer\.(?:json|lock)|package\.json|wgw-config(?:\.sample)?\.php|\.env)$ - [F,L,NC]

    # Copy Authorization into the env var Sabre's stack reads.
    RewriteCond %{HTTP:Authorization} .+
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteRule ^index\.php$ - [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . index.php [L]
</IfModule>
