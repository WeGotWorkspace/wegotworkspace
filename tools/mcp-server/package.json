{
  "name": "@wgw/mcp-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "MCP verification server — callable done gates and quality checks for AI agents",
  "bin": {
    "wgw-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
