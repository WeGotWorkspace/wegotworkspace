# Copy to .env and adjust before: docker compose up -d --build
#
# See docs/install-docker.md for full reference.

# --- Compose profiles ---
# mysql (default): web + MariaDB — use during /install/ wizard with MySQL
# sqlite:          web only — choose SQLite in the installer wizard
COMPOSE_PROFILES=mysql

# --- Published image (pull from GHCR on tagged releases) ---
# WGW_IMAGE=ghcr.io/wegotworkspace/wegotworkspace:1.0.0

# --- HTTP ---
WGW_HTTP_PORT=8080

# --- Web container → MySQL (when COMPOSE_PROFILES=mysql) ---
WGW_WAIT_FOR_DB=1
WGW_DB_HOST=db
WGW_DB_PORT=3306
WGW_DB_USERNAME=wgw
WGW_DB_PASSWORD=wgw

# --- MariaDB service (profile: mysql) ---
MARIADB_ROOT_PASSWORD=wgw-root
MARIADB_DATABASE=wgw
MARIADB_USER=wgw
MARIADB_PASSWORD=wgw

# --- Headless install (optional — skip web wizard when all WGW_INSTALL_* vars are set in api.env) ---
# WGW_INSTALL_HEADLESS=1
# WGW_INSTALL_BASE_URI=/
# WGW_INSTALL_ADMIN_USERNAME=admin
# WGW_INSTALL_ADMIN_EMAIL=admin@example.com
# WGW_INSTALL_ADMIN_PASSWORD=change-me-long-password
