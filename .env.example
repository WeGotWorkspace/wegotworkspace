# Repo-root tooling only (loaded by tools/with-root-env.sh for pnpm/turbo scripts).
# Laravel runtime config lives in packages/api/.env — do not duplicate APP_KEY or DB_* here.
#
# Copy to .env (gitignored) when you need these values locally.

# Optional: RSA PEM for manifest.sig / checksum signatures (release ZIPs)
# WGW_RELEASE_SIGNING_PRIVATE_KEY="$(cat ~/.ssh/wgw-key.pem)"
#
# Optional: SSH public key path for signed git tags (pnpm release:publish); not the PEM above
# WGW_GIT_SIGNING_PUBLIC_KEY=$HOME/.ssh/id_ed25519.pub

# Optional: local vhost name for Docker HTTPS / mkcert (default wegotworkspace.local)
# VHOST_DOMAIN=wegotworkspace.local

# Optional: disable login throttle in local Docker/host API testing
# WGW_DISABLE_LOGIN_THROTTLE=1
