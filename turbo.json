{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "SABRE_BUILD_DIR",
    "SABRE_PUBLIC_DIR_NAME",
    "SABRE_PRIVATE_DIR_NAME",
    "SABRE_DATA_DIR_NAME",
    "SABRE_DATA_DIR"
  ],
  "globalDependencies": ["packages/api/composer.json", "packages/api/composer.lock"],
  "tasks": {
    "preview:macos": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build", "typegen"],
      "cache": false,
      "outputs": [
        "../../packages/api/vendor/**",
        "../../apps/wegotworkspace/wgw-modules/office/build/**",
        "../../apps/wegotworkspace/wgw-modules/admin/dist/**",
        "../../apps/wegotworkspace/wgw-modules/settings/dist/**",
        "../../apps/wegotworkspace/wgw-modules/drive/dist/**",
        "../../apps/wegotworkspace/wgw-modules/voice/dist/**",
        "../../apps/wegotworkspace/wgw-modules/mail/dist/**",
        "../../apps/wegotworkspace/wgw-modules/notes/dist/**",
        "../../apps/wegotworkspace/wgw-modules/home/dist/**",
        "../../apps/wegotworkspace/wgw-modules/install/dist/**"
      ]
    },
    "typegen": {
      "dependsOn": ["^typegen"],
      "cache": false,
      "outputs": ["openapi/generated/**"]
    },
    "typegen:check": {
      "dependsOn": ["typegen", "^typegen:check"],
      "cache": false
    },
    "typegen:watch": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "dev:php": {
      "cache": false,
      "persistent": true
    },
    "watch": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
