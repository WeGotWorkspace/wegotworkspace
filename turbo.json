{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "SABRE_BUILD_DIR",
    "SABRE_PUBLIC_DIR_NAME",
    "SABRE_PRIVATE_DIR_NAME",
    "SABRE_DATA_DIR_NAME",
    "SABRE_DATA_DIR"
  ],
  "globalDependencies": [
    "packages/api/package.json",
    "packages/api/composer.json",
    "packages/api/composer.lock",
    "packages/api/openapi/openapi.json"
  ],
  "tasks": {
    "preview:macos": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build", "typegen"],
      "cache": false,
      "outputs": [
        "../../packages/api/vendor/**",
        "../../apps/wegotworkspace/packages/api/**",
        "../../apps/wegotworkspace/packages/apps/office/build/**",
        "../../apps/wegotworkspace/packages/apps/*/dist/**"
      ]
    },
    "typegen": {
      "dependsOn": ["^typegen"],
      "cache": false,
      "outputs": ["openapi/generated/**"]
    },
    "typegen:check": {
      "dependsOn": ["typegen", "^typegen:check"],
      "cache": false
    },
    "typegen:watch": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "dev:php": {
      "cache": false,
      "persistent": true
    },
    "watch": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
