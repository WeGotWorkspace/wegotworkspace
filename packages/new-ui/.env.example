# --- WeGotWorkspace live API (optional) ---
# 1. Copy this file to `.env.local` in the same directory (gitignored via `*.local`).
# 2. Fill in credentials. Run `npm run dev` or `npm run storybook` — `/api/v1` is proxied
#    (see vite.config.ts and .storybook/main.ts). Live API stories: Apps/Mail/Live API, Apps/Notes/Live API.

VITE_WGW_USE_LIVE_API=1
VITE_WGW_API_BASE_URL=/api/v1
VITE_WGW_DEV_USERNAME=
VITE_WGW_DEV_PASSWORD=

# Proxy target for `vite` dev server only (not bundled into the client).
WGW_PROXY_TARGET=https://wegotworkspace.local:8443
