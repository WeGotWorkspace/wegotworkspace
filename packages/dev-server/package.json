{
  "name": "@wgw/dev-server",
  "private": true,
  "dependencies": {
    "@wgw/apps": "workspace:*",
    "@wgw/php-deps": "workspace:*",
    "@wgw/onlyoffice-web": "workspace:*"
  },
  "scripts": {
    "dev": "sh -c 'app_root=\"../../apps/wegotworkspace\"; env -u SABRE_BUILD_DIR php -S 127.0.0.1:8080 -t \"$app_root\" \"$app_root/index.php\"'",
    "dev:php": "sh -c 'app_root=\"../../apps/wegotworkspace\"; env -u SABRE_BUILD_DIR php -S 127.0.0.1:8080 -t \"$app_root\" \"$app_root/index.php\"'"
  }
}
