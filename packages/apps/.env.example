# --- WeGotWorkspace Live API (Storybook / Vite proxy) ---
# Copy to repo root as `.env.local` (gitignored). Laravel secrets stay in packages/api/.env — see docs/env.md.
#
# Default dev: `pnpm dev` → full app http://127.0.0.1:5173, Storybook http://127.0.0.1:6006
# Vite and Storybook proxy `/api/v1` → `WGW_PROXY_TARGET` (vite.config.ts, .storybook/main.ts).

VITE_WGW_USE_LIVE_API=1
VITE_WGW_API_BASE_URL=/api/v1
# Local install user (see tools/setup-storybook-live-api.sh)
VITE_WGW_DEV_USERNAME=admin
VITE_WGW_DEV_PASSWORD=storybook-dev
# Optional explicit live origin used by collab stories.
VITE_WGW_LIVE_ORIGIN=https://wegotworkspace.localhost

# Debug: force TURN relay-only ICE (meet/docs). Not for production admin.
# VITE_WGW_RTC_FORCE_RELAY=1

# Proxy target for Storybook/Vite only (not bundled into the client).
# API origin for Storybook/Vite proxy (`pnpm dev`, `pnpm dev:api`, or `pnpm docker:up` on :9080).
# Use https://wegotworkspace.localhost when running `pnpm docker:up:https` without plain HTTP on :9080.
WGW_PROXY_TARGET=http://127.0.0.1:9080
