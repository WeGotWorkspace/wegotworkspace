# --- WeGotWorkspace Live API (Storybook / Vite proxy) ---
# Copy to repo root as `.env.local` (gitignored). Laravel secrets stay in packages/api/.env — see docs/env.md.
#
# Default dev: `pnpm docker:up` then `pnpm dev:ui` → open http://127.0.0.1:6006
# Storybook proxies `/api/v1` → `WGW_PROXY_TARGET` (vite.config.ts, .storybook/main.ts).

VITE_WGW_USE_LIVE_API=1
VITE_WGW_API_BASE_URL=/api/v1
# Local install user (see tools/setup-storybook-live-api.sh)
VITE_WGW_DEV_USERNAME=admin
VITE_WGW_DEV_PASSWORD=storybook-dev

# Proxy target for Storybook/Vite only (not bundled into the client).
# API origin for Storybook/Vite proxy (`pnpm dev`, `pnpm dev:api`, or `pnpm docker:up`).
WGW_PROXY_TARGET=http://127.0.0.1:9080
