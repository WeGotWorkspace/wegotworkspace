# --- WeGotWorkspace live API (Storybook / Vite proxy) ---
# 1. Copy this file to the **repo root** as `.env.local` (gitignored via `*.local`).
# 2. Fill in credentials below.
# 3. `pnpm dev` (Storybook :6006 + PHP API :9080 + UI watch). Or `pnpm dev:ui` + `pnpm dev:api` in two terminals.
#
# Storybook/Vite proxy `/api/v1` → `WGW_PROXY_TARGET` (see vite.config.ts, .storybook/main.ts).
# Live API story: Apps/WeGotWorkspace → Live API.

VITE_WGW_USE_LIVE_API=1
VITE_WGW_API_BASE_URL=/api/v1
VITE_WGW_DEV_USERNAME=
VITE_WGW_DEV_PASSWORD=

# Proxy target for Storybook/Vite only (not bundled into the client).
# API origin for Storybook/Vite proxy (`pnpm dev`, `pnpm dev:api`, or `pnpm docker:up`).
WGW_PROXY_TARGET=http://127.0.0.1:9080
