{
    "name": "wgw/api",
    "description": "WeGotWorkspace Laravel REST API (greenfield)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.44",
        "lcobucci/jwt": "^5.5",
        "phpmailer/phpmailer": "^6.9",
        "sabre/dav": "^4.7",
        "swagger-api/swagger-ui": "^5.32",
        "zbateson/mail-mime-parser": "^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "lint": "php scripts/greenfield-guard.php",
        "format": "vendor/bin/pint",
        "format:check": "vendor/bin/pint --test",
        "test": "phpunit -c phpunit.xml",
        "test:mysql": "WGW_TEST_DRIVER=mysql phpunit -c phpunit.xml",
        "test:architecture": "phpunit -c phpunit.xml --testsuite Architecture",
        "greenfield:guard": "@lint",
        "done-gate:contract": [
            "@greenfield:guard",
            "@test:architecture"
        ],
        "done-gate": [
            "@done-gate:contract",
            "@test"
        ],
        "done-gate:full": [
            "@done-gate:contract",
            "@test",
            "@test:mysql"
        ],
        "prune": [
            "@composer install --no-dev --prefer-dist --optimize-autoloader --no-interaction"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.3.99"
        },
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
