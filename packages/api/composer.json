{
    "name": "wgw/api",
    "description": "Core WeGotWorkspace PHP backend runtime and REST API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-ctype": "*",
        "ext-dom": "*",
        "ext-iconv": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-simplexml": "*",
        "ext-zip": "*",
        "lcobucci/jwt": "^5.5",
        "phpmailer/phpmailer": "^6.9",
        "psr/log": "^1.1 || ^2.0 || ^3.0",
        "sabre/dav": "^4.7",
        "swagger-api/swagger-ui": "^5.32",
        "symfony/cache": "^8.0",
        "symfony/rate-limiter": "^8.0",
        "zbateson/mail-mime-parser": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "audit": {
            "block-insecure": false
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml"
    },
    "suggest": {
        "ext-imap": "Required for /mail IMAP sync (folders, read, send uses SMTP separately)",
        "ext-openssl": "Used to encrypt per-user mail passwords on disk",
        "ext-pdo_sqlite": "Default database backend for the installer",
        "ext-pdo_mysql": "Optional MySQL / MariaDB support"
    }
}
