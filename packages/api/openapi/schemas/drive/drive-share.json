{
  "DriveShareAccess": {
    "type": "string",
    "enum": ["view", "comment", "review", "edit", "full"],
    "description": "Share access level for a grant or default access."
  },
  "DriveRights": {
    "type": "object",
    "required": [
      "mayView",
      "mayComment",
      "mayReview",
      "mayEditContent",
      "mayManageStructure",
      "mayShare"
    ],
    "properties": {
      "mayView": { "type": "boolean" },
      "mayComment": { "type": "boolean" },
      "mayReview": { "type": "boolean" },
      "mayEditContent": { "type": "boolean" },
      "mayManageStructure": { "type": "boolean" },
      "mayShare": { "type": "boolean" }
    },
    "additionalProperties": false,
    "description": "Effective drive rights for the current principal on a path or share."
  },
  "DriveShareGrantEntry": {
    "type": "object",
    "required": ["access"],
    "properties": {
      "access": { "$ref": "#/components/schemas/DriveShareAccess" }
    },
    "additionalProperties": false
  },
  "DriveShareShareWithMap": {
    "type": "object",
    "additionalProperties": {
      "oneOf": [
        { "$ref": "#/components/schemas/DriveShareGrantEntry" },
        { "type": "null" }
      ]
    },
    "description": "Map of username, groups/{slug}, or email to grant entry; null value removes the grant. On CRUD responses, contains active user and group grants only — pending email invites are omitted (see effectiveGrants on at-path)."
  },
  "DriveShare": {
    "type": "object",
    "required": [
      "id",
      "path",
      "kind",
      "defaultAccess",
      "hasPassword",
      "myRights"
    ],
    "properties": {
      "id": { "type": "string", "format": "uuid" },
      "path": { "type": "string" },
      "kind": {
        "type": "string",
        "enum": ["public", "member", "guest"]
      },
      "defaultAccess": { "$ref": "#/components/schemas/DriveShareAccess" },
      "publicToken": { "type": ["string", "null"] },
      "hasPassword": { "type": "boolean" },
      "expiresAt": { "type": ["string", "null"], "format": "date-time" },
      "updatedAt": { "type": ["string", "null"], "format": "date-time" },
      "shareWith": {
        "oneOf": [
          { "$ref": "#/components/schemas/DriveShareShareWithMap" },
          { "type": "null" }
        ],
        "description": "Active user and group grants only (PATCH-editable). Pending email invites are not included — use effectiveGrants on GET /files/shares/at-path for the full principal overview."
      },
      "myRights": { "$ref": "#/components/schemas/DriveRights" }
    },
    "additionalProperties": false
  },
  "DriveShareDataResponse": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": { "$ref": "#/components/schemas/DriveShare" }
    },
    "additionalProperties": false
  },
  "DriveShareListDataResponse": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/DriveShare" }
      }
    },
    "additionalProperties": false
  },
  "DriveShareCreateRequest": {
    "type": "object",
    "required": ["path", "kind", "defaultAccess"],
    "properties": {
      "path": { "type": "string" },
      "kind": {
        "type": "string",
        "enum": ["public", "member", "guest"]
      },
      "defaultAccess": { "$ref": "#/components/schemas/DriveShareAccess" },
      "expiresAt": { "type": ["string", "null"], "format": "date-time" },
      "password": { "type": ["string", "null"] },
      "shareWith": {
        "oneOf": [
          { "$ref": "#/components/schemas/DriveShareShareWithMap" },
          { "type": "null" }
        ]
      }
    },
    "additionalProperties": false
  },
  "DriveShareUpdateRequest": {
    "type": "object",
    "required": ["updatedAt"],
    "properties": {
      "updatedAt": { "type": "string", "format": "date-time" },
      "defaultAccess": { "$ref": "#/components/schemas/DriveShareAccess" },
      "expiresAt": { "type": ["string", "null"], "format": "date-time" },
      "password": { "type": ["string", "null"] },
      "shareWith": {
        "oneOf": [
          { "$ref": "#/components/schemas/DriveShareShareWithMap" },
          { "type": "null" }
        ]
      }
    },
    "additionalProperties": false
  },
  "DriveShareDeletedResponse": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": { "type": "string", "const": "Deleted" }
    },
    "additionalProperties": false
  },
  "DriveShareInvite": {
    "type": "object",
    "required": ["id", "email", "access", "inviteToken"],
    "properties": {
      "id": { "type": "string", "format": "uuid" },
      "email": { "type": "string", "format": "email" },
      "access": { "$ref": "#/components/schemas/DriveShareAccess" },
      "inviteToken": { "type": "string" }
    },
    "additionalProperties": false
  },
  "DriveShareInviteDataResponse": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": { "$ref": "#/components/schemas/DriveShareInvite" }
    },
    "additionalProperties": false
  },
  "DriveShareInviteCreateRequest": {
    "type": "object",
    "required": ["email", "access"],
    "properties": {
      "email": { "type": "string", "format": "email" },
      "access": { "$ref": "#/components/schemas/DriveShareAccess" }
    },
    "additionalProperties": false
  },
  "DriveShareSessionCreateRequest": {
    "type": "object",
    "required": ["token"],
    "properties": {
      "token": { "type": "string" },
      "password": { "type": ["string", "null"] }
    },
    "additionalProperties": false
  },
  "DriveShareSessionShareSummary": {
    "type": "object",
    "required": ["id", "path", "defaultAccess"],
    "properties": {
      "id": { "type": "string", "format": "uuid" },
      "path": { "type": "string" },
      "defaultAccess": { "$ref": "#/components/schemas/DriveShareAccess" }
    },
    "additionalProperties": false
  },
  "DriveShareSessionResponse": {
    "type": "object",
    "required": [
      "access_token",
      "token_type",
      "expires_in",
      "role",
      "username",
      "share"
    ],
    "properties": {
      "access_token": { "type": "string" },
      "token_type": { "type": "string" },
      "expires_in": { "type": "integer" },
      "role": { "type": "string", "enum": ["guest"] },
      "username": {
        "type": "string",
        "description": "Opaque share session subject (share:{sessionKey})."
      },
      "share": { "$ref": "#/components/schemas/DriveShareSessionShareSummary" }
    },
    "additionalProperties": false
  },
  "DriveShareAcceptRequest": {
    "type": "object",
    "required": ["inviteToken"],
    "properties": {
      "inviteToken": { "type": "string" }
    },
    "additionalProperties": false
  },
  "DriveShareAcceptResult": {
    "type": "object",
    "required": ["shareId", "accepted"],
    "properties": {
      "shareId": { "type": "string", "format": "uuid" },
      "accepted": { "type": "boolean", "const": true }
    },
    "additionalProperties": false
  },
  "DriveShareAcceptDataResponse": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": { "$ref": "#/components/schemas/DriveShareAcceptResult" }
    },
    "additionalProperties": false
  },
  "DriveSharedWithMeEntry": {
    "type": "object",
    "required": ["share"],
    "properties": {
      "share": { "$ref": "#/components/schemas/DriveShare" },
      "viaGroup": {
        "type": "string",
        "description": "Present when access is group-only (groups/{slug} grant). Omitted when the caller has a direct user grant on the same share."
      }
    },
    "additionalProperties": false
  },
  "DriveSharedWithMeDataResponse": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/DriveSharedWithMeEntry" }
      }
    },
    "additionalProperties": false
  },
  "DriveShareConflictError": {
    "allOf": [
      { "$ref": "#/components/schemas/Error" },
      {
        "type": "object",
        "required": ["code"],
        "properties": {
          "code": { "type": "string", "const": "share_conflict" }
        }
      }
    ]
  },
  "DriveShareAtPathEntryStatus": {
    "type": "string",
    "enum": ["active", "expired"],
    "description": "Share lifecycle status for owner overview. Expired shares remain visible but do not confer live access."
  },
  "DriveShareAtPathRelationship": {
    "type": "string",
    "enum": ["direct", "ancestor", "descendant"]
  },
  "DriveShareAtPathEntry": {
    "type": "object",
    "required": ["share", "relationship", "status"],
    "properties": {
      "share": { "$ref": "#/components/schemas/DriveShare" },
      "relationship": { "$ref": "#/components/schemas/DriveShareAtPathRelationship" },
      "status": { "$ref": "#/components/schemas/DriveShareAtPathEntryStatus" }
    },
    "additionalProperties": false
  },
  "DriveShareGrantSource": {
    "type": "object",
    "required": ["shareId", "sharePath", "inherited", "status"],
    "properties": {
      "shareId": { "type": "string", "format": "uuid" },
      "sharePath": { "type": "string" },
      "inherited": {
        "type": "boolean",
        "description": "true when sharePath !== requested path (ancestor or descendant)."
      },
      "status": {
        "$ref": "#/components/schemas/DriveShareAtPathEntryStatus",
        "description": "Share lifecycle status (active or expired). Distinct from top-level invite/grant status on grant rows."
      }
    },
    "additionalProperties": false
  },
  "DriveShareEffectiveGrantPrincipalType": {
    "type": "string",
    "enum": ["user", "group", "email"]
  },
  "DriveShareEffectiveGrantStatus": {
    "type": "string",
    "enum": ["pending", "active"]
  },
  "DriveShareGrantRemoval": {
    "type": "object",
    "required": ["method", "shareId"],
    "properties": {
      "method": {
        "type": "string",
        "enum": ["deleteInvite", "patchShareWith"]
      },
      "shareId": { "type": "string", "format": "uuid" },
      "principal": {
        "type": "string",
        "description": "Username or groups/{slug} for patchShareWith removal."
      }
    },
    "additionalProperties": false
  },
  "DriveShareGrantSourceEntry": {
    "type": "object",
    "required": ["principal", "principalType", "access", "source"],
    "properties": {
      "principal": {
        "type": "string",
        "description": "Username, groups/{slug}, or email address."
      },
      "principalType": { "$ref": "#/components/schemas/DriveShareEffectiveGrantPrincipalType" },
      "access": { "$ref": "#/components/schemas/DriveShareAccess" },
      "status": { "$ref": "#/components/schemas/DriveShareEffectiveGrantStatus" },
      "source": { "$ref": "#/components/schemas/DriveShareGrantSource" }
    },
    "additionalProperties": false,
    "description": "Raw grant row before resolver merge — one entry per overlapping grant source in the audit subtree (direct, ancestor, and descendant shares)."
  },
  "DriveShareMemberAccessEditConstraint": {
    "type": "string",
    "enum": ["directGrant", "groupOnly"]
  },
  "DriveShareMemberAccess": {
    "type": "object",
    "required": [
      "username",
      "displayName",
      "access",
      "viaGroup",
      "editable",
      "source",
      "removal"
    ],
    "properties": {
      "username": { "type": "string" },
      "displayName": { "type": "string" },
      "access": { "$ref": "#/components/schemas/DriveShareAccess" },
      "viaGroup": {
        "type": ["string", "null"],
        "description": "groups/{slug} when winning access is via a group grant; null when direct user grant wins."
      },
      "editable": { "type": "boolean" },
      "editConstraint": { "$ref": "#/components/schemas/DriveShareMemberAccessEditConstraint" },
      "editHint": { "type": "string" },
      "source": { "$ref": "#/components/schemas/DriveShareGrantSource" },
      "removal": { "$ref": "#/components/schemas/DriveShareGrantRemoval" }
    },
    "additionalProperties": false,
    "description": "Per-user resolved access for the team panel, with group expansion and editability hints."
  },
  "DriveSharePrincipalEntry": {
    "type": "object",
    "required": ["principal", "principalType", "displayName"],
    "properties": {
      "principal": {
        "type": "string",
        "description": "Username or groups/{slug}."
      },
      "principalType": {
        "type": "string",
        "enum": ["user", "group"]
      },
      "displayName": { "type": "string" },
      "memberCount": {
        "type": "integer",
        "description": "Present for group principals."
      }
    },
    "additionalProperties": false
  },
  "DriveSharePrincipalsResponse": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/DriveSharePrincipalEntry" }
      }
    },
    "additionalProperties": false
  },
  "DriveShareEffectiveGrant": {
    "type": "object",
    "required": ["principal", "principalType", "access", "source"],
    "properties": {
      "principal": {
        "type": "string",
        "description": "Username, groups/{slug}, or email address."
      },
      "principalType": { "$ref": "#/components/schemas/DriveShareEffectiveGrantPrincipalType" },
      "access": { "$ref": "#/components/schemas/DriveShareAccess" },
      "status": { "$ref": "#/components/schemas/DriveShareEffectiveGrantStatus" },
      "inviteId": {
        "type": "string",
        "format": "uuid",
        "description": "Pending email invite grant id."
      },
      "invitedEmail": {
        "type": "string",
        "format": "email",
        "description": "Original invite email for accepted guest user grants."
      },
      "displayName": {
        "type": "string",
        "description": "Group display name when principalType is group."
      },
      "memberCount": {
        "type": "integer",
        "description": "Group member count when principalType is group."
      },
      "source": { "$ref": "#/components/schemas/DriveShareGrantSource" },
      "removal": { "$ref": "#/components/schemas/DriveShareGrantRemoval" }
    },
    "additionalProperties": false,
    "description": "Resolved grant overview at a path — one row per principal with winning access and provenance."
  },
  "DriveSharePublicSummary": {
    "type": "object",
    "required": [
      "shareId",
      "sharePath",
      "defaultAccess",
      "hasPassword",
      "inherited",
      "status"
    ],
    "properties": {
      "shareId": { "type": "string", "format": "uuid" },
      "sharePath": { "type": "string" },
      "defaultAccess": { "$ref": "#/components/schemas/DriveShareAccess" },
      "hasPassword": { "type": "boolean" },
      "inherited": { "type": "boolean" },
      "status": { "$ref": "#/components/schemas/DriveShareAtPathEntryStatus" }
    },
    "additionalProperties": false,
    "description": "Owner overview of applicable public shares in the audit subtree (direct, ancestor, and descendant). Guest sessions remain 1:1 bound to a single share token — no prefix-winner resolution."
  },
  "DriveShareAtPath": {
    "type": "object",
    "required": [
      "path",
      "directShares",
      "coveringShares",
      "nestedShares",
      "grantSources",
      "effectiveGrants",
      "memberAccess",
      "publicShares",
      "myRights"
    ],
    "properties": {
      "path": { "type": "string" },
      "directShares": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/DriveShareAtPathEntry" }
      },
      "coveringShares": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/DriveShareAtPathEntry" }
      },
      "nestedShares": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/DriveShareAtPathEntry" }
      },
      "grantSources": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/DriveShareGrantSourceEntry" },
        "description": "Subtree audit rows — all non-revoked grant sources on direct, ancestor, and descendant shares (including expired shares)."
      },
      "effectiveGrants": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/DriveShareEffectiveGrant" },
        "description": "Resolved grants — one row per principal with winning access."
      },
      "memberAccess": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/DriveShareMemberAccess" }
      },
      "publicShares": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/DriveSharePublicSummary" },
        "description": "Public shares in the audit subtree (direct, ancestor, and descendant), including expired links."
      },
      "myRights": { "$ref": "#/components/schemas/DriveRights" }
    },
    "additionalProperties": false
  },
  "DriveShareAtPathDataResponse": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": { "$ref": "#/components/schemas/DriveShareAtPath" }
    },
    "additionalProperties": false
  },
  "DriveShareRevokeAllPublicResult": {
    "type": "object",
    "required": ["revokedCount", "shareIds"],
    "properties": {
      "revokedCount": { "type": "integer", "minimum": 0 },
      "shareIds": {
        "type": "array",
        "items": { "type": "string", "format": "uuid" }
      }
    },
    "additionalProperties": false
  },
  "DriveShareRevokeAllPublicDataResponse": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": { "$ref": "#/components/schemas/DriveShareRevokeAllPublicResult" }
    },
    "additionalProperties": false
  },
  "DriveShareByPrincipalRelationship": {
    "type": "string",
    "enum": ["direct", "ancestor", "descendant"]
  },
  "DriveShareByPrincipalEntry": {
    "type": "object",
    "required": ["access", "principalType", "source", "relationship", "status"],
    "properties": {
      "access": { "$ref": "#/components/schemas/DriveShareAccess" },
      "principalType": {
        "$ref": "#/components/schemas/DriveShareEffectiveGrantPrincipalType",
        "description": "Grant row type (user, group, or email) — same semantics as effectiveGrants grantSources, not the queried principal."
      },
      "status": {
        "$ref": "#/components/schemas/DriveShareEffectiveGrantStatus",
        "description": "Invite/grant status (pending or active). Share lifecycle is on source.status."
      },
      "invitedEmail": {
        "type": "string",
        "format": "email",
        "description": "Original invite email for accepted guest user grants."
      },
      "viaGroup": {
        "type": "string",
        "description": "Present when a user principal matched via a group grant (groups/{slug})."
      },
      "source": { "$ref": "#/components/schemas/DriveShareGrantSource" },
      "relationship": { "$ref": "#/components/schemas/DriveShareByPrincipalRelationship" },
      "removal": { "$ref": "#/components/schemas/DriveShareGrantRemoval" }
    },
    "additionalProperties": false,
    "description": "One grant row for the queried principal — audit list without resolver merge."
  },
  "DriveShareByPrincipal": {
    "type": "object",
    "required": ["principal", "queriedPrincipalType", "entries"],
    "properties": {
      "principal": {
        "type": "string",
        "description": "Queried username, groups/{slug}, or email address (normalized from the principal query parameter)."
      },
      "queriedPrincipalType": {
        "$ref": "#/components/schemas/DriveShareEffectiveGrantPrincipalType",
        "description": "Type inferred from the principal query parameter (user, group, or email)."
      },
      "entries": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/DriveShareByPrincipalEntry" }
      }
    },
    "additionalProperties": false
  },
  "DriveShareByPrincipalDataResponse": {
    "type": "object",
    "required": ["data"],
    "properties": {
      "data": { "$ref": "#/components/schemas/DriveShareByPrincipal" }
    },
    "additionalProperties": false
  }
}
