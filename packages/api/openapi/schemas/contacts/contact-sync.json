{
  "AddressBookCreate": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      },
      "description": {
        "type": ["string", "null"]
      },
      "id": {
        "$ref": "#/components/schemas/JsContactId",
        "description": "Optional client-suggested address book id (uri slug)."
      }
    },
    "additionalProperties": false
  },
  "AddressBookPatch": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 255
      },
      "description": {
        "type": ["string", "null"]
      },
      "isSubscribed": {
        "type": "boolean"
      }
    },
    "additionalProperties": false
  },
  "AddressBookDeleteOptions": {
    "type": "object",
    "properties": {
      "onDestroyRemoveContents": {
        "type": "boolean",
        "default": false,
        "description": "When true, delete all cards in the book before destroying it."
      }
    },
    "additionalProperties": false
  },
  "JmapChangesResponse": {
    "type": "object",
    "required": ["oldState", "newState", "created", "updated", "destroyed"],
    "properties": {
      "oldState": {
        "type": "string",
        "description": "Previous sync state token supplied by the client."
      },
      "newState": {
        "type": "string",
        "description": "Current sync state token to store for the next request."
      },
      "created": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/JsContactId"
        }
      },
      "updated": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/JsContactId"
        }
      },
      "destroyed": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/JsContactId"
        }
      }
    },
    "additionalProperties": false,
    "description": "JMAP-shaped incremental sync response (RFC 8620 /changes mapping)."
  },
  "ContactCardQueryFilter": {
    "type": "object",
    "required": ["inAddressBook"],
    "properties": {
      "inAddressBook": {
        "$ref": "#/components/schemas/JsContactId"
      },
      "uid": {
        "type": "string",
        "description": "Exact JSContact uid match (RFC 9610 ContactCard/query)."
      }
    },
    "additionalProperties": false
  },
  "ContactCardQueryRequest": {
    "type": "object",
    "required": ["filter"],
    "properties": {
      "filter": {
        "$ref": "#/components/schemas/ContactCardQueryFilter"
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500
      }
    },
    "additionalProperties": false
  },
  "ContactCardQueryResponse": {
    "type": "object",
    "required": ["ids", "total"],
    "properties": {
      "ids": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/JsContactId"
        }
      },
      "total": {
        "type": "integer",
        "minimum": 0
      }
    },
    "additionalProperties": false
  }
}
