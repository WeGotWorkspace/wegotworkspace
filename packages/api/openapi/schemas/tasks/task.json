{
  "TaskAlertOffsetTrigger": {
    "type": "object",
    "required": ["@type", "offset"],
    "properties": {
      "@type": { "type": "string", "const": "OffsetTrigger" },
      "offset": { "type": "string", "description": "Signed ISO 8601 duration (e.g. -PT30M)" },
      "relativeTo": {
        "type": "string",
        "enum": ["start", "end"],
        "default": "start",
        "description": "Relative to task start (DTSTART) or end/due (DUE)"
      }
    },
    "additionalProperties": false
  },
  "TaskAlertAbsoluteTrigger": {
    "type": "object",
    "required": ["@type", "when"],
    "properties": {
      "@type": { "type": "string", "const": "AbsoluteTrigger" },
      "when": { "type": "string", "description": "UTC date-time when the alert fires" }
    },
    "additionalProperties": false
  },
  "TaskAlert": {
    "type": "object",
    "required": ["@type", "trigger"],
    "properties": {
      "@type": { "type": "string", "const": "Alert" },
      "trigger": {
        "oneOf": [
          { "$ref": "#/components/schemas/TaskAlertOffsetTrigger" },
          { "$ref": "#/components/schemas/TaskAlertAbsoluteTrigger" }
        ]
      },
      "action": { "type": "string", "enum": ["display", "email"] },
      "acknowledged": { "type": "string" }
    },
    "additionalProperties": false
  },
  "TaskRecurrenceOverride": {
    "type": "object",
    "properties": {
      "title": { "type": "string" },
      "description": { "type": ["string", "null"] },
      "start": { "type": ["string", "null"] },
      "due": { "type": ["string", "null"] },
      "completed": { "type": ["string", "null"] },
      "showWithoutTime": { "type": "boolean" },
      "timeZone": { "type": ["string", "null"] },
      "workflowStatus": { "type": ["string", "null"] },
      "progress": { "type": ["integer", "null"] },
      "excluded": { "type": "boolean", "description": "When true, exclude this recurrence instance (EXDATE)" }
    },
    "additionalProperties": false
  },
  "TaskParticipant": {
    "type": "object",
    "required": ["@type"],
    "properties": {
      "@type": { "type": "string", "const": "Participant" },
      "name": { "type": ["string", "null"] },
      "email": { "type": ["string", "null"] },
      "roles": { "type": "array", "items": { "type": "string" } },
      "participationStatus": { "type": "string" },
      "kind": { "type": "string" },
      "language": { "type": "string" }
    },
    "additionalProperties": false
  },
  "Task": {
    "type": "object",
    "required": ["@type", "id", "taskListId", "uid", "isDraft", "sortOrder"],
    "properties": {
      "@type": { "type": "string", "enum": ["Task"] },
      "id": { "type": "string" },
      "taskListId": { "type": "string" },
      "uid": { "type": "string" },
      "title": { "type": ["string", "null"] },
      "description": { "type": ["string", "null"] },
      "start": { "type": ["string", "null"] },
      "due": { "type": ["string", "null"] },
      "completed": { "type": ["string", "null"] },
      "showWithoutTime": { "type": "boolean" },
      "timeZone": { "type": ["string", "null"] },
      "workflowStatus": { "type": ["string", "null"] },
      "progress": { "type": ["integer", "null"] },
      "priority": { "type": ["integer", "null"] },
      "isDraft": { "type": "boolean" },
      "sortOrder": { "type": "integer" },
      "categories": { "type": "array", "items": { "type": "string" } },
      "privacy": { "type": ["string", "null"] },
      "created": { "type": ["string", "null"] },
      "updated": { "type": ["string", "null"] },
      "etag": { "$ref": "#/components/schemas/DavEtag" },
      "recurrenceRules": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/CalendarRecurrenceRule" },
        "description": "RRULE-only; clients expand instances per JMAP Tasks draft."
      },
      "excludedRecurrenceDates": {
        "type": "array",
        "items": { "type": "string" },
        "description": "EXDATE values for excluded recurrence instances."
      },
      "recurrenceOverrides": {
        "type": "object",
        "additionalProperties": { "$ref": "#/components/schemas/TaskRecurrenceOverride" },
        "description": "Per-instance patches keyed by recurrence id (RECURRENCE-ID)."
      },
      "alerts": {
        "type": "object",
        "additionalProperties": { "$ref": "#/components/schemas/TaskAlert" },
        "description": "Task reminders mapped from VALARM components."
      },
      "participants": {
        "type": "object",
        "propertyNames": { "$ref": "#/components/schemas/JmapId" },
        "additionalProperties": { "$ref": "#/components/schemas/TaskParticipant" },
        "description": "Task assignees mapped from ORGANIZER/ATTENDEE."
      },
      "icsProps": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "Unmapped VTODO properties preserved for round-trip fidelity."
      }
    },
    "additionalProperties": false
  },
  "TaskListResponse": {
    "type": "object",
    "required": ["list"],
    "properties": {
      "list": { "type": "array", "items": { "$ref": "#/components/schemas/Task" } }
    },
    "additionalProperties": false
  },
  "TaskCreate": {
    "type": "object",
    "required": ["taskListIds", "title"],
    "properties": {
      "taskListIds": { "type": "object", "additionalProperties": { "type": "boolean" } },
      "uid": { "type": "string" },
      "title": { "type": "string" },
      "description": { "type": ["string", "null"] },
      "start": { "type": ["string", "null"] },
      "due": { "type": ["string", "null"] },
      "completed": { "type": ["string", "null"] },
      "showWithoutTime": { "type": "boolean" },
      "timeZone": { "type": ["string", "null"] },
      "workflowStatus": { "type": ["string", "null"] },
      "progress": { "type": ["integer", "null"] },
      "priority": { "type": ["integer", "null"] },
      "categories": { "type": "array", "items": { "type": "string" } },
      "privacy": { "type": ["string", "null"] },
      "recurrenceRules": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/CalendarRecurrenceRule" }
      },
      "excludedRecurrenceDates": { "type": "array", "items": { "type": "string" } },
      "recurrenceOverrides": {
        "type": "object",
        "additionalProperties": { "$ref": "#/components/schemas/TaskRecurrenceOverride" }
      },
      "alerts": {
        "type": "object",
        "additionalProperties": { "$ref": "#/components/schemas/TaskAlert" }
      },
      "participants": {
        "type": "object",
        "propertyNames": { "$ref": "#/components/schemas/JmapId" },
        "additionalProperties": { "$ref": "#/components/schemas/TaskParticipant" }
      },
      "icsProps": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      }
    },
    "additionalProperties": false
  },
  "TaskPatch": {
    "type": "object",
    "properties": {
      "title": { "type": "string" },
      "description": { "type": ["string", "null"] },
      "start": { "type": ["string", "null"] },
      "due": { "type": ["string", "null"] },
      "completed": { "type": ["string", "null"] },
      "showWithoutTime": { "type": "boolean" },
      "timeZone": { "type": ["string", "null"] },
      "workflowStatus": { "type": ["string", "null"] },
      "progress": { "type": ["integer", "null"] },
      "priority": { "type": ["integer", "null"] },
      "categories": { "type": "array", "items": { "type": "string" } },
      "privacy": { "type": ["string", "null"] },
      "recurrenceRules": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/CalendarRecurrenceRule" }
      },
      "excludedRecurrenceDates": { "type": "array", "items": { "type": "string" } },
      "recurrenceOverrides": {
        "type": "object",
        "additionalProperties": { "$ref": "#/components/schemas/TaskRecurrenceOverride" }
      },
      "alerts": {
        "type": "object",
        "additionalProperties": { "$ref": "#/components/schemas/TaskAlert" }
      },
      "participants": {
        "type": "object",
        "propertyNames": { "$ref": "#/components/schemas/JmapId" },
        "additionalProperties": { "$ref": "#/components/schemas/TaskParticipant" }
      },
      "icsProps": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      }
    },
    "additionalProperties": false
  }
}
