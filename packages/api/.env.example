# Laravel API runtime — copy to packages/api/.env (not the repo root).
# Repo-root tooling: see /.env.example and docs/env.md.

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Laravel framework DB only (sessions/cache when using database drivers).
# WeGotWorkspace app data (users, mail, …) uses WGW_DB_* below → wgw-content/.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# File drivers work on Apache/shared hosting without packages/api/database/database.sqlite.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# JWT signing (RS256) — required for POST /api/v1/auth/token on host PHP dev.
# Install tree (default): php packages/api/artisan wgw:jwt-keys → apps/wegotworkspace/wgw-content/keys/
# Host-only keys: bash packages/api/scripts/generate-jwt-keys.sh → packages/api/storage/app/jwt/
# Paths below are relative to install root (apps/wegotworkspace); uncomment after generate-jwt-keys.sh:
# WGW_API_JWT_PRIVATE_KEY_PATH=../../packages/api/storage/app/jwt/api-jwt-private.pem
# WGW_API_JWT_PUBLIC_KEY_PATH=../../packages/api/storage/app/jwt/api-jwt-public.pem
# WGW_API_JWT_ISSUER=wegotworkspace-api
# WGW_API_JWT_AUDIENCE=wegotworkspace-clients

# WeGotWorkspace app bootstrap (runtime — written by installer or migrate from legacy wgw-config.php)
WGW_DATA_DIR=./wgw-content
WGW_DB_CONNECTION=sqlite
WGW_DB_DATABASE=./wgw-content/db.sqlite
# WGW_UPDATE_FEED_URL=https://github.com/WeGotWorkspace/wegotworkspace/releases/latest/download/manifest.json

# MySQL app database (comment SQLite lines above and uncomment below)
# WGW_DB_CONNECTION=mysql
# WGW_DB_HOST=127.0.0.1
# WGW_DB_PORT=3306
# WGW_DB_DATABASE=wegotworkspace
# WGW_DB_USERNAME=wgw
# WGW_DB_PASSWORD=secret

# Installer autofill / headless install (see docs/install-docker.md and config/wgw.php install section)
# WGW_INSTALL_HEADLESS=1
# WGW_INSTALL_DB_DRIVER=mysql
# WGW_INSTALL_DB_HOST=db
# WGW_INSTALL_DB_PORT=3306
# WGW_INSTALL_DB_DATABASE=wgw
# WGW_INSTALL_DB_USER=wgw
# WGW_INSTALL_DB_PASSWORD=wgw
# WGW_INSTALL_BASE_URI=/
# WGW_INSTALL_BASE_URI_AUTO=0
# WGW_INSTALL_TIMEZONE=UTC
# WGW_INSTALL_ADMIN_USERNAME=admin
# WGW_INSTALL_ADMIN_EMAIL=admin@example.com
# WGW_INSTALL_ADMIN_PASSWORD=
# WGW_INSTALL_CHANNEL=docker
