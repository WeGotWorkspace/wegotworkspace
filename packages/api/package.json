{
  "name": "@wgw/api",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "composer run-script prune && node scripts/prune-swagger-ui-vendor.mjs && node scripts/sync-runtime-api-package.mjs --with-vendor",
    "watch:runtime": "node scripts/watch-runtime-api-package.mjs",
    "sync:runtime": "node scripts/sync-runtime-api-package.mjs --with-vendor",
    "dev": "pnpm run dev:php",
    "dev:php": "sh -c 'app_root=\"../../apps/wegotworkspace\"; env -u SABRE_BUILD_DIR php -S 127.0.0.1:9080 -t \"$app_root\" \"$app_root/index.php\"'",
    "openapi:build-json": "node scripts/build-openapi-built-json.mjs",
    "typegen": "pnpm run typegen:openapi",
    "typegen:check": "pnpm run typegen:openapi:check",
    "typegen:watch": "pnpm run typegen:openapi:watch",
    "typegen:openapi": "node scripts/typegen-openapi-types.mjs",
    "typegen:openapi:watch": "node scripts/typegen-openapi-types-watch.mjs",
    "typegen:openapi:check": "pnpm run typegen:openapi && git diff --exit-code -- openapi/generated/openapi.built.json openapi/generated/openapi-types.ts openapi/generated/mail-types.ts openapi/generated/notes-types.ts openapi/generated/settings-types.ts openapi/generated/settings-request-zod.ts openapi/generated/admin-types.ts openapi/generated/drive-types.ts openapi/generated/voice-types.ts",
    "typegen:mail": "pnpm run typegen:openapi",
    "typegen:mail:watch": "pnpm run typegen:openapi:watch",
    "typegen:mail:check": "pnpm run typegen:openapi:check",
    "lint": "composer lint",
    "format": "composer format",
    "format:check": "composer format:check",
    "test": "composer run-script done-gate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "chokidar": "^5.0.0",
    "openapi-typescript": "^7.13.0",
    "zod": "^3.24.2"
  }
}
