{
  "name": "@wgw/api",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "setup:macos": "bash scripts/macos/install-homebrew-apache-ssl.sh",
    "preview:macos": "bash scripts/macos/setup-homebrew-apache-ssl.sh",
    "enable-php-imap": "bash scripts/macos/enable-php-imap.sh",
    "generate:api-jwt-keys": "bash scripts/generate-api-jwt-keys.sh",
    "openapi:build-json": "node scripts/build-openapi-built-json.mjs",
    "typegen": "pnpm run typegen:openapi",
    "typegen:check": "pnpm run typegen:openapi:check",
    "typegen:watch": "pnpm run typegen:openapi:watch",
    "typegen:openapi": "node scripts/typegen-openapi-types.mjs",
    "typegen:openapi:watch": "node scripts/typegen-openapi-types-watch.mjs",
    "typegen:openapi:check": "pnpm run typegen:openapi && git diff --exit-code -- openapi/generated/openapi.built.json openapi/generated/openapi-types.ts openapi/generated/mail-types.ts openapi/generated/notes-types.ts openapi/generated/settings-types.ts",
    "typegen:mail": "pnpm run typegen:openapi",
    "typegen:mail:watch": "pnpm run typegen:openapi:watch",
    "typegen:mail:check": "pnpm run typegen:openapi:check",
    "test:update-smoke": "bash scripts/update-smoke-test.sh",
    "test": "vendor/bin/phpunit -c phpunit.xml"
  },
  "devDependencies": {
    "chokidar": "^5.0.0",
    "openapi-typescript": "^7.13.0"
  }
}
